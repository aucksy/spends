<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Phase 1 needs no special permissions: manual entry + timeline + analytics only, fully offline.
      SMS (READ_SMS/RECEIVE_SMS), NotificationListener access, POST_NOTIFICATIONS, biometric, and the
      Drive/Internet permissions are introduced in their own phases (see docs/PLATFORM_NOTES.md).
      We deliberately do NOT declare USE_FULL_SCREEN_INTENT — Play revoked it for non-call/alarm apps;
      captures will use a high-importance heads-up notification instead.
    -->

    <!-- Drive backup: the only network the app does is the user's own Google Drive. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- SMS capture (PRD §4.1): read bank transaction texts, on-device only, behind a rationale +
         runtime grant. Parsing happens locally; nothing is uploaded. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- "Prompt me on each SMS" capture mode posts a heads-up Add/Edit/Ignore notification (Android 13+
         runtime grant). No full-screen intent — Play-compliant. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Onboarding battery step (#10): ask to exempt Spends from battery optimization so background SMS/
         notification capture isn't killed on aggressive OEMs. Optional; the user can decline. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Recurring reminder (#4): fire the daily "recurring added" pass on an EXACT alarm so it lands at the
         chosen time instead of drifting under Doze. USE_EXACT_ALARM auto-grants on Android 13+ (reminder is
         the feature's core function); SCHEDULE_EXACT_ALARM covers Android 12. RECEIVE_BOOT_COMPLETED re-arms
         the alarm after a reboot (exact alarms don't survive a restart). -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Light haptic "tick" confirming taps on the home-screen widget buttons (eye / quick-add "+"),
         whose taps fire a PendingIntent so there's no View to drive performHapticFeedback. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".core.SpendsApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Spends"
        tools:targetApi="34">

        <activity
            android:name=".core.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Spends.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Standalone quick-add overlay (#1): the home-screen widgets' "+" launch this transparent
             activity so only the keypad sheet appears (home shows behind), never the full app/list — and
             a future app-lock on MainActivity won't gate it. Its own task affinity + excludeFromRecents
             keep it a transient overlay that never surfaces the main app task.
             NOTE: deliberately NO android:noHistory here. noHistory finishes the activity the moment you
             leave it, which wiped a half-typed entry the instant you switched to another app (#2). Without
             it the overlay is retained when backgrounded (singleInstance → re-tapping the widget returns to
             the same instance), and QuickAddSheet's rememberSaveable fields also survive a process-death
             recreate — so in-progress work is kept. It still finishes on save / ✕ / back. -->
        <activity
            android:name=".core.QuickAddActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:taskAffinity="${applicationId}.quickadd"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Spends.Transparent"
            android:windowSoftInputMode="adjustResize" />

        <!-- Invisible foreground trampoline for the summary widget's eye (#1): a background broadcast can't
             vibrate on many OEMs, so the eye launches this transparent, no-UI activity to fire the haptic
             from the foreground, hands the mask-toggle back to SummaryWidget, and finishes immediately. -->
        <activity
            android:name=".widget.WidgetEyeToggleActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:taskAffinity="${applicationId}.eyetoggle"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Spends.Transparent" />

        <!-- Live SMS capture receiver. BROADCAST_SMS permission ensures only the system delivers it. -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Add / Ignore actions of the capture-prompt notification (internal only). -->
        <receiver
            android:name=".receiver.CaptureActionReceiver"
            android:exported="false" />

        <!-- Exact-alarm target for the daily recurring pass (#4). Not exported: it's only ever triggered by
             our own explicit-component PendingIntent via AlarmManager. -->
        <receiver
            android:name=".receiver.RecurringAlarmReceiver"
            android:exported="false" />

        <!-- Re-arm the recurring exact alarm after a reboot (#4). Exported so the system can deliver
             BOOT_COMPLETED; guarded by RECEIVE_BOOT_COMPLETED. -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Home-screen quick-add widget (#14): a tap opens the quick-add sheet. Exported so the system
             AppWidgetService can deliver APPWIDGET_UPDATE; it only fires an immutable PendingIntent to
             our own activity and shows no data. -->
        <receiver
            android:name=".widget.QuickAddWidget"
            android:exported="true"
            android:label="@string/widget_quick_add_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_add_info" />
        </receiver>

        <!-- Home-screen summary widget (#2): shows Income/Expense/Balance for the current cycle with a
             per-widget eye to hide/show. Exported for APPWIDGET_UPDATE delivery; reads data locally. -->
        <receiver
            android:name=".widget.SummaryWidget"
            android:exported="true"
            android:label="@string/widget_summary_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_summary_info" />
        </receiver>

        <!--
          Disable WorkManager's default initializer so it uses our Hilt-aware Configuration.Provider
          (SpendsApp). Workers themselves arrive in later phases (recurring generation, daily Drive
          snapshot, capture health-check); the factory is wired now so they drop in cleanly.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
