<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Phase 1 needs no special permissions: manual entry + timeline + analytics only, fully offline.
      SMS (READ_SMS/RECEIVE_SMS), NotificationListener access, POST_NOTIFICATIONS, biometric, and the
      Drive/Internet permissions are introduced in their own phases (see docs/PLATFORM_NOTES.md).
      We deliberately do NOT declare USE_FULL_SCREEN_INTENT — Play revoked it for non-call/alarm apps;
      captures will use a high-importance heads-up notification instead.
    -->

    <!-- Drive backup: the only network the app does is the user's own Google Drive. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- SMS capture (PRD §4.1): read bank transaction texts, on-device only, behind a rationale +
         runtime grant. Parsing happens locally; nothing is uploaded. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- "Prompt me on each SMS" capture mode posts a heads-up Add/Edit/Ignore notification (Android 13+
         runtime grant). No full-screen intent — Play-compliant. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Onboarding battery step (#10): ask to exempt Spends from battery optimization so background SMS/
         notification capture isn't killed on aggressive OEMs. Optional; the user can decline. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".core.SpendsApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Spends"
        tools:targetApi="34">

        <activity
            android:name=".core.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Spends.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Live SMS capture receiver. BROADCAST_SMS permission ensures only the system delivers it. -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Add / Ignore actions of the capture-prompt notification (internal only). -->
        <receiver
            android:name=".receiver.CaptureActionReceiver"
            android:exported="false" />

        <!-- Home-screen quick-add widget (#14): a tap opens the quick-add sheet. Exported so the system
             AppWidgetService can deliver APPWIDGET_UPDATE; it only fires an immutable PendingIntent to
             our own activity and shows no data. -->
        <receiver
            android:name=".widget.QuickAddWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_add_info" />
        </receiver>

        <!--
          Disable WorkManager's default initializer so it uses our Hilt-aware Configuration.Provider
          (SpendsApp). Workers themselves arrive in later phases (recurring generation, daily Drive
          snapshot, capture health-check); the factory is wired now so they drop in cleanly.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
