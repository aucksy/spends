<?xml version="1.0" encoding="utf-8"?>
<!-- Circular, slightly-raised "3D" button for the summary widget's eye + "+" (#2). A top-to-bottom
     gradient (lighter top, darker bottom) over the teal card reads as a raised disc; the thin rim adds
     definition. RemoteViews can't do real elevation/ripple, so this static gradient is the 3D cue. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#1A8E82"
        android:endColor="#0A544D" />
    <stroke
        android:width="1dp"
        android:color="#2FA496" />
</shape>
