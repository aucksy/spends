<?xml version="1.0" encoding="utf-8"?>
<!-- Circular "domed" 3D button for the summary widget's eye + add (design: a teal dome, lighter top →
     darker bottom). RemoteViews can't draw the design's drop/inset shadows, so a 3-stop vertical gradient
     (highlight top, mid, deep base) + a light rim stroke approximate the raised dome as closely as a
     widget allows. Colours match the design's button gradient #23938a → #137a70 → #0c6259. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#23938A"
        android:centerColor="#137A70"
        android:endColor="#0C6259" />
    <stroke
        android:width="1dp"
        android:color="#36A99B" />
</shape>
