<?xml version="1.0" encoding="utf-8"?>
<!-- Summary widget (#2): the teal card with two circular, raised "3D" buttons pinned to the right
     corners — eye top-right, "+" bottom-right — so they line up with each other and the card's rounded
     corners regardless of size (a FrameLayout pins them; the content reserves a right gutter so it never
     runs under them). NOTE: only RemoteViews-allowed classes (FrameLayout/LinearLayout/TextView/ImageView)
     — a bare <View>/Space crashes the launcher with "couldn't load widget". -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_summary_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_summary_bg"
    android:padding="10dp">

    <!-- Content fills the card; paddingEnd reserves room so text never sits under the corner buttons. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingTop="4dp"
        android:paddingEnd="44dp">

        <TextView
            android:id="@+id/widget_summary_cycle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#A7E0D8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="BALANCE" />

        <TextView
            android:id="@+id/widget_summary_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:text="••••" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A7E0D8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:text="Expense" />

                <TextView
                    android:id="@+id/widget_summary_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:text="••••" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A7E0D8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:text="Income" />

                <TextView
                    android:id="@+id/widget_summary_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:text="••••" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Eye: top-right corner, circular 3D button (hide/show). -->
    <ImageView
        android:id="@+id/widget_summary_eye"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:padding="9dp"
        android:scaleType="fitCenter"
        android:background="@drawable/widget_circle_button"
        android:src="@drawable/ic_widget_eye"
        android:contentDescription="Show amounts" />

    <!-- "+": bottom-right corner, circular 3D button (opens quick-add). Lines up under the eye. -->
    <ImageView
        android:id="@+id/widget_summary_add"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:padding="9dp"
        android:scaleType="fitCenter"
        android:background="@drawable/widget_circle_button"
        android:src="@drawable/ic_widget_plus"
        android:contentDescription="Add transaction" />
</FrameLayout>
