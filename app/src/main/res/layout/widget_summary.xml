<?xml version="1.0" encoding="utf-8"?>
<!-- Summary widget (#2): the compact teal card the user liked. Eye top-right (hide/show); the "+"
     (opens the quick-add overlay) sits at the bottom-right, on the Expense/Income row just to the right
     of Income — so it lines up directly under the eye. Both are a matched pair, ~32dp. The whole card
     opens the app. NOTE: only RemoteViews-allowed classes here (LinearLayout/TextView/ImageView) — a bare
     <View>/Space crashes the launcher with "couldn't load widget". -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_summary_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_summary_bg"
    android:padding="14dp">

    <!-- Top row: cycle name (fills) + eye (top-right). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_summary_cycle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#A7E0D8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="BALANCE" />

        <ImageView
            android:id="@+id/widget_summary_eye"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_eye"
            android:contentDescription="Show amounts" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_summary_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:text="••••" />

    <!-- Bottom row: Expense | Income | "+". The "+" sits to the right of Income (which shifts left),
         vertically centred, lining up under the eye on the card's right edge. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A7E0D8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Expense" />

            <TextView
                android:id="@+id/widget_summary_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:text="••••" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A7E0D8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Income" />

            <TextView
                android:id="@+id/widget_summary_income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:text="••••" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_summary_add"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:layout_marginStart="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_plus"
            android:contentDescription="Add transaction" />
    </LinearLayout>
</LinearLayout>
