<?xml version="1.0" encoding="utf-8"?>
<!-- Summary widget (#2): a teal card showing Balance + Expense/Income for the current cycle. The eye
     (top-right, hide/show) and a "+" (bottom-right, opens the standalone quick-add overlay) are a
     matched pair on the right edge — same size, diagonally aligned. The whole card opens the app.
     NOTE: every view here MUST be a RemoteViews-allowed class (LinearLayout / TextView / ImageView);
     a bare <View> spacer is NOT allowed and makes the launcher fail with "couldn't load widget". -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_summary_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_summary_bg"
    android:padding="14dp">

    <!-- Top row: cycle name (fills) + eye (top-right). Original layout the user liked, eye 10% larger. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_summary_cycle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#A7E0D8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="BALANCE" />

        <ImageView
            android:id="@+id/widget_summary_eye"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:padding="3dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_eye"
            android:contentDescription="Show amounts" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_summary_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:text="••••" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A7E0D8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Expense" />

            <TextView
                android:id="@+id/widget_summary_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:text="••••" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A7E0D8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Income" />

            <TextView
                android:id="@+id/widget_summary_income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:text="••••" />
        </LinearLayout>
    </LinearLayout>

    <!-- This expanding row pushes the "+" to the card's bottom-right corner, mirroring the eye top-right
         (no <View> spacer — that crashes RemoteViews). wrap_content (not 0dp) reserves the icon's own
         height as the row's floor, so even if the sp text above grows at a large font scale the weighted
         leftover can't squeeze the "+" to nothing; minResizeHeight also blocks shrinking past the content. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="bottom|end">

        <ImageView
            android:id="@+id/widget_summary_add"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:padding="3dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_plus"
            android:contentDescription="Add transaction" />
    </LinearLayout>
</LinearLayout>
