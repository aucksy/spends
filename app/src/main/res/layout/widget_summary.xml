<?xml version="1.0" encoding="utf-8"?>
<!-- Summary widget, built to the "Spends Summary Widget" design: a teal gradient card with the title at
     top, the balance centred, and Expense/Income at the bottom, plus two circular "domed" buttons inset
     in the RIGHT corners (eye top-right, add bottom-right, same right edge). A FrameLayout pins the
     buttons to the corners at any size; the content reserves a right gutter so it never runs under them.
     NOTE: only RemoteViews-allowed classes here (FrameLayout/LinearLayout/TextView/ImageView) — a bare
     <View>/Space crashes the launcher with "couldn't load widget" (empty LinearLayouts are the spacers). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_summary_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_summary_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="64dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/widget_summary_cycle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#9EC9C2"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="BALANCE" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/widget_summary_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:text="••••" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#9EC9C2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="Expense" />

                <TextView
                    android:id="@+id/widget_summary_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:text="••••" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#9EC9C2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="Income" />

                <TextView
                    android:id="@+id/widget_summary_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:text="••••" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Eye: top-right corner, circular domed button (hide/show). -->
    <ImageView
        android:id="@+id/widget_summary_eye"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:padding="11dp"
        android:scaleType="fitCenter"
        android:background="@drawable/widget_circle_button"
        android:src="@drawable/ic_widget_eye"
        android:contentDescription="Show amounts" />

    <!-- Add: bottom-right corner, circular domed button. Same right edge as the eye. -->
    <ImageView
        android:id="@+id/widget_summary_add"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="14dp"
        android:layout_marginEnd="14dp"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:background="@drawable/widget_circle_button"
        android:src="@drawable/ic_widget_plus"
        android:contentDescription="Add transaction" />
</FrameLayout>
